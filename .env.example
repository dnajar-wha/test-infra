# HAProxy Stats Dashboard
HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASS=change-me-in-production

# Docker Registry (optional - leave empty for local builds)
REGISTRY=
# REGISTRY=ghcr.io/yourorg

# App version tag (auto-generated if empty)
APP_VERSION=

# Network name (auto-discovered if empty)
NETWORK_NAME=

# Jenkins
JENKINS_USER=admin
JENKINS_TOKEN=
